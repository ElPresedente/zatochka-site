# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/zatochka

# Node environment
NODE_ENV=development

# Session signing secret (min 32 chars)
SESSION_SECRET=change-me-to-a-32-char-random-string

# First admin credentials (used by db:seed)
ADMIN_PHONE=+79000000000
ADMIN_PASSWORD=changeme

#Telegram bot settings
TELEGRAM_BOT_TOKEN=XXXXX
TELEGRAM_CHAT_ID=XXXXX

# ЮKassa платежи (https://yookassa.ru)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Базовый URL сайта (для return_url при оплате), например: https://example.ru
SITE_URL=

# Яндекс.Карты (developer.tech.yandex.ru — каждый продукт имеет свой ключ)
# JavaScript API — для загрузки карты и виджета СДЭК
YANDEX_MAPS_JS_API_KEY=
# HTTP Геокодер — для геокодирования адресов (серверная сторона)
YANDEX_MAPS_GEOCODER_KEY=
# HTTP Геосаджест — для подсказок при вводе адреса (может совпадать с Геокодером)
YANDEX_MAPS_SUGGEST_KEY=

# СДЭК (cdek.ru/ru/business/api)
# Тестовые значения оставлены по умолчанию — замените на боевые перед запуском
CDEK_ACCOUNT=EMscd6r9JnFiQ3bLoyjJY6eM
CDEK_SECURE=PjLZkKBHEiLK3YsjtNrt3TGNG0ahs3kG
# Поставьте false для отключения тестового режима СДЭК
CDEK_TEST_MODE=true
