# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/zatochka

# Node environment
NODE_ENV=development

# Session signing secret (min 32 chars)
SESSION_SECRET=change-me-to-a-32-char-random-string

# First admin credentials (used by db:seed)
ADMIN_PHONE=+79000000000
ADMIN_PASSWORD=changeme

#Telegram bot settings
TELEGRAM_BOT_TOKEN=XXXXX
TELEGRAM_CHAT_ID=XXXXX
